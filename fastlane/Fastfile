default_platform(:ios)

# ──────────────────────────────────────────
# iOS Lanes
# ──────────────────────────────────────────
platform :ios do

  desc "Distribution cert limiti doluysa en eskiyi iptal et"
  private_lane :ensure_cert_slot do |options|
    api_key = options[:api_key]
    require 'jwt'
    require 'net/http'
    require 'json'
    require 'openssl'

    # app_store_connect_api_key :key içeriği döndürür, :key_filepath değil
    key     = OpenSSL::PKey::EC.new(api_key[:key])
    payload = { iss: api_key[:issuer_id], exp: Time.now.to_i + 1200, aud: 'appstoreconnect-v1' }
    token   = JWT.encode(payload, key, 'ES256', { kid: api_key[:key_id] })
    headers = { 'Authorization' => "Bearer #{token}", 'Content-Type' => 'application/json' }

    uri  = URI('https://api.appstoreconnect.apple.com/v1/certificates?filter[certificateType]=DISTRIBUTION')
    req  = Net::HTTP::Get.new(uri, headers)
    resp = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |h| h.request(req) }
    certs = JSON.parse(resp.body)['data'] || []

    UI.message("Mevcut Distribution sertifika sayisi: #{certs.count}")
    if certs.count >= 2
      oldest  = certs.min_by { |c| c['attributes']['expirationDate'] }
      cert_id = oldest['id']
      UI.important("Limit doldu — iptal ediliyor: #{oldest['attributes']['displayName']} (#{cert_id})")
      del_uri  = URI("https://api.appstoreconnect.apple.com/v1/certificates/#{cert_id}")
      del_req  = Net::HTTP::Delete.new(del_uri, headers)
      del_resp = Net::HTTP.start(del_uri.hostname, del_uri.port, use_ssl: true) { |h| h.request(del_req) }
      del_resp.code == '204' ? UI.success("Iptal edildi.") : UI.error("Iptal basarisiz: #{del_resp.code}")
    end
  end

  desc "App Store Connect API key objesi oluştur"
  private_lane :asc_key do
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_KEY_PATH"],
      duration: 1200,
      in_house: false
    )
  end

  desc "Flutter build + TestFlight upload"
  lane :beta do
    api_key = asc_key
    build_number = (ENV["BUILD_NUMBER"] || "1").to_i

    ensure_cert_slot(api_key: api_key)
    cert(
      api_key: api_key,
      output_path: "/tmp/ios_certs"
    )

    sh("cd .. && flutter build ios --release --no-codesign --build-number #{build_number} --split-debug-info=build/debug-info")

    # -allowProvisioningUpdates: Xcode provisioning profile'ı ASC API ile otomatik yönetir
    build_app(
      workspace: "ios/Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build/ios/ipa",
      xcargs: "-allowProvisioningUpdates " \
              "-authenticationKeyPath '#{ENV['APP_STORE_CONNECT_KEY_PATH']}' " \
              "-authenticationKeyID #{ENV['APP_STORE_CONNECT_KEY_ID']} " \
              "-authenticationKeyIssuerID #{ENV['APP_STORE_CONNECT_ISSUER_ID']}"
    )
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
    slack_notify("iOS beta yuklendi") if ENV["SLACK_URL"]
  end

  desc "Tüm cihaz boyutları için screenshot al (simülatörde)"
  lane :screenshots do
    # Flutter integration_test tabanlı snapshot
    snapshot(
      scheme: "Runner",
      output_directory: "./fastlane/screenshots",
      clear_previous_screenshots: true,
      override_status_bar: true,
      concurrent_simulators: false,
      devices: [
        "iPhone 16 Pro Max",
        "iPhone 15 Plus",
        "iPhone 8 Plus",
        "iPhone SE (3rd generation)"
      ],
      languages: ["tr-TR", "en-US"],
      test_target_name: "RunnerUITests"
    )
  end

  desc "App Store'a gönder (review)"
  lane :release do
    api_key = asc_key
    build_number = (ENV["BUILD_NUMBER"] || "1").to_i

    ensure_cert_slot(api_key: api_key)
    cert(
      api_key: api_key,
      output_path: "/tmp/ios_certs"
    )

    sh("cd .. && flutter build ios --release --no-codesign --build-number #{build_number} --split-debug-info=build/debug-info")
    build_app(
      workspace: "ios/Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates " \
              "-authenticationKeyPath '#{ENV['APP_STORE_CONNECT_KEY_PATH']}' " \
              "-authenticationKeyID #{ENV['APP_STORE_CONNECT_KEY_ID']} " \
              "-authenticationKeyIssuerID #{ENV['APP_STORE_CONNECT_ISSUER_ID']}"
    )
    upload_to_app_store(
      api_key: api_key,
      submit_for_review: false,
      automatic_release: false,
      skip_screenshots: false,
      screenshots_path: "./fastlane/screenshots",
      skip_metadata: false,
      metadata_path: "./fastlane/metadata/ios"
    )
  end

end

# ──────────────────────────────────────────
# Android Lanes
# ──────────────────────────────────────────
platform :android do

  desc "Flutter build + Google Play Internal Track"
  lane :beta do
    build_number = (ENV["BUILD_NUMBER"] || "1").to_i
    sh("cd .. && flutter build appbundle --release --build-number #{build_number} --split-debug-info=build/debug-info")
    upload_to_play_store(
      track: "internal",
      aab: "../build/app/outputs/bundle/release/app-release.aab",
      json_key: ENV["GOOGLE_PLAY_JSON_KEY"],
      package_name: "com.nickdegs.sosyalpanel",
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
    slack_notify("Android beta yüklendi 🤖") if ENV["SLACK_URL"]
  end

  desc "Google Play Production'a terfi et"
  lane :release do
    upload_to_play_store(
      track: "internal",
      track_promote_to: "production",
      json_key: ENV["GOOGLE_PLAY_JSON_KEY"],
      package_name: "com.nickdegs.sosyalpanel",
      skip_upload_apk: true,
      skip_upload_aab: true
    )
  end

end

# ──────────────────────────────────────────
# Ortak
# ──────────────────────────────────────────
def slack_notify(msg)
  slack(message: msg, slack_url: ENV["SLACK_URL"]) rescue nil
end
