default_platform(:ios)

# ──────────────────────────────────────────
# iOS Lanes
# ──────────────────────────────────────────
platform :ios do

  desc "Sertifikaları ve provisioning profile'ları senkronize et (Match)"
  lane :certs do
    match(
      type: "appstore",
      app_identifier: "com.nickdegs.sosyalpanel",
      readonly: is_ci,
      git_url: ENV["MATCH_GIT_URL"],
      git_basic_authorization: ENV["MATCH_GIT_AUTH"]
    )
  end

  desc "Flutter build + TestFlight upload"
  lane :beta do
    certs
    increment_build_number(xcodeproj: "ios/Runner.xcodeproj")
    sh("cd .. && /snap/bin/flutter build ipa --release --no-codesign")
    build_app(
      workspace: "ios/Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      output_directory: "build/ios/ipa"
    )
    upload_to_testflight(
      api_key_path: ENV["APP_STORE_CONNECT_API_KEY_PATH"],
      skip_waiting_for_build_processing: true
    )
    slack_notify("iOS beta yüklendi 🚀") if ENV["SLACK_URL"]
  end

  desc "App Store'a gönder (review)"
  lane :release do
    certs
    build_number = ENV["BUILD_NUMBER"] || "1"
    sh("cd .. && /snap/bin/flutter build ipa --release --build-number #{build_number}")
    build_app(
      workspace: "ios/Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store"
    )
    upload_to_app_store(
      api_key_path: ENV["APP_STORE_CONNECT_API_KEY_PATH"],
      submit_for_review: false,
      automatic_release: false,
      skip_screenshots: true,
      skip_metadata: false,
      metadata_path: "./fastlane/metadata/ios"
    )
  end

end

# ──────────────────────────────────────────
# Android Lanes
# ──────────────────────────────────────────
platform :android do

  desc "Flutter build + Google Play Internal Track"
  lane :beta do
    build_number = (ENV["BUILD_NUMBER"] || "1").to_i
    sh("cd .. && /snap/bin/flutter build appbundle --release --build-number #{build_number}")
    upload_to_play_store(
      track: "internal",
      aab: "../build/app/outputs/bundle/release/app-release.aab",
      json_key: ENV["GOOGLE_PLAY_JSON_KEY"],
      package_name: "com.nickdegs.sosyalpanel",
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
    slack_notify("Android beta yüklendi 🤖") if ENV["SLACK_URL"]
  end

  desc "Google Play Production'a terfi et"
  lane :release do
    upload_to_play_store(
      track: "internal",
      track_promote_to: "production",
      json_key: ENV["GOOGLE_PLAY_JSON_KEY"],
      package_name: "com.nickdegs.sosyalpanel",
      skip_upload_apk: true,
      skip_upload_aab: true
    )
  end

end

# ──────────────────────────────────────────
# Ortak
# ──────────────────────────────────────────
def slack_notify(msg)
  slack(message: msg, slack_url: ENV["SLACK_URL"]) rescue nil
end
