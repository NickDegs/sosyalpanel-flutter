default_platform(:ios)

# ──────────────────────────────────────────
# iOS Lanes
# ──────────────────────────────────────────
platform :ios do

  desc "App Store Connect API key objesi oluştur"
  private_lane :asc_key do
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_KEY_PATH"],
      duration: 1200,
      in_house: false
    )
  end

  desc "Flutter build + TestFlight upload"
  lane :beta do
    api_key = asc_key
    build_number = (ENV["BUILD_NUMBER"] || "1").to_i

    # Sertifika workflow'da keychain'e import edildi (DIST_CERT_P12 secret)
    # cert_id: Apple Distribution X5MSF5DD53 — sosyalpanel için kanonik cert
    sigh(
      api_key: api_key,
      app_identifier: "com.nickdegs.sosyalpanel",
      output_path: "/tmp/ios_profiles",
      force: true,
      cert_id: "X5MSF5DD53"
    )
    profile_uuid = lane_context[SharedValues::SIGH_UUID]

    # Sadece Runner target için manual signing + profil ata (Pods/SPM miras almaz)
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/Runner.xcodeproj",
      team_id: ENV["APPLE_TEAM_ID"],
      bundle_identifier: "com.nickdegs.sosyalpanel",
      code_sign_identity: "Apple Distribution",
      profile_uuid: profile_uuid
    )

    sh("cd .. && flutter build ios --release --no-codesign --build-number #{build_number} --split-debug-info=build/debug-info")

    # DEVELOPMENT_TEAM global (tüm targetlar için), PROVISIONING_PROFILE xcargs'ta yok
    build_app(
      workspace: "ios/Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build/ios/ipa",
      xcargs: "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']}",
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        # Export compliance: uygulama standart HTTPS dışında şifreleme kullanmıyor
        compileBitcode: false,
        usesNonExemptEncryption: false,
        provisioningProfiles: {
          "com.nickdegs.sosyalpanel" => profile_uuid
        }
      }
    )
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: false,
      distribute_external: false,
      notify_external_testers: false,
      changelog: "Yeni güncelleme yüklendi"
    )

    # daclen10@icloud.com (Account Holder) ve daclen10@gmail.com'u tester listesine ekle
    ["daclen10@icloud.com", "daclen10@gmail.com"].each do |email|
      begin
        add_test_flight_tester(
          api_key: api_key,
          email: email,
          first_name: "Baris",
          last_name: "Unal",
          app_identifier: "com.nickdegs.sosyalpanel"
        )
        UI.success("Tester eklendi: #{email}")
      rescue => e
        UI.message("Tester #{email} zaten ekli veya hata: #{e.message}")
      end
    end

    slack_notify("iOS beta yuklendi") if ENV["SLACK_URL"]
  end

  desc "Tüm cihaz boyutları için screenshot al (simülatörde)"
  lane :screenshots do
    # Flutter integration_test tabanlı snapshot
    snapshot(
      scheme: "Runner",
      output_directory: "./fastlane/screenshots",
      clear_previous_screenshots: true,
      override_status_bar: true,
      concurrent_simulators: false,
      devices: [
        "iPhone 16 Pro Max",
        "iPhone 15 Plus",
        "iPhone 8 Plus",
        "iPhone SE (3rd generation)"
      ],
      languages: ["tr-TR", "en-US"],
      test_target_name: "RunnerUITests"
    )
  end

  desc "App Store'a gönder (review)"
  lane :release do
    api_key = asc_key
    build_number = (ENV["BUILD_NUMBER"] || "1").to_i

    # Sertifika workflow'da keychain'e import edildi (DIST_CERT_P12 secret)
    sigh(
      api_key: api_key,
      app_identifier: "com.nickdegs.sosyalpanel",
      output_path: "/tmp/ios_profiles",
      force: true,
      cert_id: "X5MSF5DD53"
    )
    profile_uuid = lane_context[SharedValues::SIGH_UUID]

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/Runner.xcodeproj",
      team_id: ENV["APPLE_TEAM_ID"],
      bundle_identifier: "com.nickdegs.sosyalpanel",
      code_sign_identity: "Apple Distribution",
      profile_uuid: profile_uuid
    )

    sh("cd .. && flutter build ios --release --no-codesign --build-number #{build_number} --split-debug-info=build/debug-info")
    build_app(
      workspace: "ios/Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      export_method: "app-store",
      xcargs: "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']}",
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        compileBitcode: false,
        usesNonExemptEncryption: false,
        provisioningProfiles: {
          "com.nickdegs.sosyalpanel" => profile_uuid
        }
      }
    )
    upload_to_app_store(
      api_key: api_key,
      submit_for_review: false,
      automatic_release: false,
      skip_screenshots: false,
      screenshots_path: "./fastlane/screenshots",
      skip_metadata: false,
      metadata_path: "./fastlane/metadata/ios"
    )
  end

end

# ──────────────────────────────────────────
# Android Lanes
# ──────────────────────────────────────────
platform :android do

  desc "Flutter build + Google Play Internal Track"
  lane :beta do
    build_number = (ENV["BUILD_NUMBER"] || "1").to_i
    sh("cd .. && flutter build appbundle --release --build-number #{build_number} --split-debug-info=build/debug-info")
    upload_to_play_store(
      track: "internal",
      aab: "build/app/outputs/bundle/release/app-release.aab",
      json_key: ENV["GOOGLE_PLAY_JSON_KEY"],
      package_name: "com.nickdegs.sosyalpanel",
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
    slack_notify("Android beta yüklendi 🤖") if ENV["SLACK_URL"]
  end

  desc "Google Play Production'a terfi et"
  lane :release do
    upload_to_play_store(
      track: "internal",
      track_promote_to: "production",
      json_key: ENV["GOOGLE_PLAY_JSON_KEY"],
      package_name: "com.nickdegs.sosyalpanel",
      skip_upload_apk: true,
      skip_upload_aab: true
    )
  end

end

# ──────────────────────────────────────────
# Ortak
# ──────────────────────────────────────────
def slack_notify(msg)
  slack(message: msg, slack_url: ENV["SLACK_URL"]) rescue nil
end
